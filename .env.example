# DeepSeek API Key（在 https://platform.deepseek.com 获取）
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Kafka（默认本地 Docker，无需修改）
KAFKA_BROKER=localhost:9092
PRODUCER_INTERVAL=10

# MySQL（默认本地 Docker，无需修改）
MYSQL_HOST=localhost
MYSQL_USER=opsuser
MYSQL_PASSWORD=opspass
MYSQL_DB=opsdb

# Prometheus（默认本地 Docker，无需修改）
PROMETHEUS_URL=http://localhost:9090

# 飞书机器人（在 https://open.feishu.cn 创建企业自建应用后填入）
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_VERIFICATION_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_BOT_PORT=8080

# 定时巡检（秒）：默认 1800 = 30分钟；调试时可设成 60
HEALTH_CHECK_INTERVAL=1800
# 巡检告警发送目标（填你和机器人的单聊 chat_id，留空则用最近一次对话的 chat_id）
FEISHU_ALERT_CHAT_ID=
